<Window x:Class="NeteasePlaylistGui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🎵 网易云歌单查询" Height="720" Width="1100"
        Background="#FF191414" WindowStartupLocation="CenterScreen"
        Foreground="White">

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部用户信息栏 -->
        <Border Grid.Row="0" Background="#FF282828" Padding="16,12">
            <StackPanel>
                <TextBlock Text="🎵 网易云歌单查询" FontSize="20" FontWeight="Bold" Foreground="#FF1DB954" Margin="0,0,0,10"/>
                <DockPanel>
                    <TextBlock Text="用户ID:" Foreground="#FFB3B3B3" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="TxtUserId" Width="180" DockPanel.Dock="Left"/>
                    <Button x:Name="BtnLoad" Content="🔍 查询" Click="BtnLoad_Click" DockPanel.Dock="Left" Margin="10,0,0,0" Width="100"/>
                    <Button x:Name="BtnDetail" Content="📋 歌曲详情" Click="BtnDetail_Click" DockPanel.Dock="Left" Margin="10,0,0,0" Width="120" IsEnabled="False"/>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                        <TextBlock Text="搜索:" Foreground="#FFB3B3B3" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="TxtSearch" Width="180" TextChanged="TxtSearch_TextChanged"/>
                    </StackPanel>
                </DockPanel>
            </StackPanel>
        </Border>

        <!-- 用户信息条 -->
        <Border x:Name="UserInfoBar" Grid.Row="1" Background="#FF1E1E1E" Padding="16,8" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="TxtUserName" FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock x:Name="TxtUserStats" FontSize="13" Foreground="#FFB3B3B3" Margin="20,0,0,0"/>
                <TextBlock x:Name="TxtPlaylistCount" FontSize="13" Foreground="#FF1DB954" Margin="20,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- 主内容区 -->
        <Grid Grid.Row="2" Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：歌单列表 -->
            <Border Grid.Column="0" Background="#FF1E1E1E" Margin="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="📋 歌单列表" FontSize="14" FontWeight="SemiBold"
                               Foreground="#FFB3B3B3" Margin="12,10,12,8"/>
                    <ListBox x:Name="LstPlaylists" Background="Transparent" BorderThickness="0"
                             Foreground="White" SelectionChanged="LstPlaylists_SelectionChanged"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,8" Margin="2,1" CornerRadius="4"
                                        Background="Transparent" Cursor="Hand">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#FF2A2A2A"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" Foreground="White"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                <TextBlock FontSize="11" Foreground="#FFB3B3B3">
                                                    <Run Text="{Binding TrackCount, Mode=OneWay}"/>
                                                    <Run Text="首"/>
                                                </TextBlock>
                                                <TextBlock FontSize="11" Foreground="#FFB3B3B3" Margin="12,0,0,0">
                                                    <Run Text="{Binding PlayCountFormatted, Mode=OneWay}"/>
                                                    <Run Text="次播放"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding PrivacyIcon}" FontSize="14"
                                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- 右侧：歌曲列表 -->
            <Border Grid.Column="1" Background="#FF191414">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" x:Name="TxtPlaylistTitle" Text="🎵 选择一个歌单查看歌曲"
                               FontSize="14" FontWeight="SemiBold" Foreground="#FFB3B3B3" Margin="16,10,16,8"/>
                    <DataGrid x:Name="DgTracks" Background="Transparent" BorderThickness="0"
                              Foreground="White" GridLinesVisibility="None"
                              HeadersVisibility="Column" IsReadOnly="True"
                              AutoGenerateColumns="False" CanUserSortColumns="True"
                              SelectionMode="Single" CanUserResizeRows="False"
                              RowBackground="Transparent" AlternatingRowBackground="#FF1E1E1E">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#FF282828"/>
                                <Setter Property="Foreground" Value="#FFB3B3B3"/>
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="10,6"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#FF333333"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FF2A2A2A"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#FF333333"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="50"/>
                            <DataGridTextColumn Header="歌曲" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="歌手" Binding="{Binding Artists}" Width="180"/>
                            <DataGridTextColumn Header="专辑" Binding="{Binding Album}" Width="180"/>
                            <DataGridTextColumn Header="时长" Binding="{Binding Duration}" Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>

        <!-- 底部状态栏 -->
        <Border Grid.Row="3" Background="#FF282828" Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="TxtStatus" Text="就绪" FontSize="12" Foreground="#FFB3B3B3"/>
                <ProgressBar x:Name="Progress" IsIndeterminate="False" Visibility="Collapsed"
                             Width="120" Height="16" Margin="16,0,0,0" Foreground="#FF1DB954"
                             Background="#FF333333"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
